# ── Copy this file to .env and fill in your values ──────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...
# Model to use — gpt-4o (default), o4-mini (cheaper), gpt-4-turbo, etc.
OPENAI_MODEL=gpt-4o

# Python — timeout per generated animation script (seconds)
PYTHON_TIMEOUT_SECONDS=120

# YouTube — download credentials.json from Google Cloud Console
# (OAuth 2.0 Desktop App credentials, YouTube Data API v3 enabled)
YOUTUBE_CLIENT_SECRETS_FILE=credentials.json
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_PRIVACY=public

# GitHub
# Path to your local git repo (can be "." if running from inside the repo)
GITHUB_REPO_LOCAL_PATH=.
GITHUB_REPO_URL=https://github.com/yourname/matlab-daily
GITHUB_BRANCH=main
# Optional: Personal Access Token for HTTPS push (leave blank if using SSH)
GITHUB_TOKEN=

# Agent behaviour
MAX_RETRIES=3
MIN_VIDEO_BYTES=10240
