# ── Copy this file to .env and fill in your values ───────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: gemini | ollama | openai
LLM_PROVIDER=gemini

# ── Gemini (FREE tier — recommended) ─────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
# Free limits: 1,500 requests/day, 1M tokens/min (gemini-2.0-flash)
GEMINI_API_KEY=AIzaSyCRXgufxQVPny5hZL0cn-EkuJJ-VIACp94
GEMINI_MODEL=gemini-2.0-flash

# ── Ollama (local, completely free) ──────────────────────────────────────────
# 1. Install: https://ollama.com
# 2. Pull a code model: ollama pull codellama
#    Other good options: deepseek-coder, qwen2.5-coder, llama3
# 3. Start server: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama

# ── OpenAI (paid, optional fallback) ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Python runner ─────────────────────────────────────────────────────────────
PYTHON_TIMEOUT_SECONDS=120

# ── YouTube ───────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=credentials.json
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_PRIVACY=public

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_REPO_LOCAL_PATH=.
GITHUB_REPO_URL=https://github.com/yourname/animation-daily
GITHUB_BRANCH=main
GITHUB_TOKEN=

# ── Agent behaviour ───────────────────────────────────────────────────────────
MAX_RETRIES=3
MIN_VIDEO_BYTES=10240
